# Copy to .env and fill in. .env is gitignored — never commit real keys.

# Required for the default Gemini backend
GEMINI_API_KEY=your-gemini-api-key-here

# Optional: override the VLM backend (gemini | qwen-vl)
# VIDAUDIT_BACKEND=gemini

# Optional: cache directory for extracted frames and VLM verifications
# VIDAUDIT_CACHE_DIR=.vidaudit_cache
